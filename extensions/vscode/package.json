{
  "name": "band-vscode",
  "displayName": "Band - Agent Workspace Manager",
  "description": "IDE extension for Band agent orchestration",
  "version": "0.1.0",
  "publisher": "band",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/band-app/band.git",
    "directory": "extensions/vscode"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "files": [
    "dist",
    "LICENSE"
  ],
  "activationEvents": [
    "workspaceContains:**/.band/config.json",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "band.setupWorkspace",
        "title": "Band: Setup Workspace"
      }
    ]
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node && npm run package",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
    "package": "vsce package --no-dependencies --out band-vscode-0.1.0.vsix"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  }
}
