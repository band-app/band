---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Band — The agent-first IDE for AI coding">
  <main class="pt-14">
    <!-- Hero Section -->
    <section class="relative overflow-hidden">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,oklch(0.922 0 0 / 0.04),transparent_60%)]"></div>
      <div class="relative mx-auto max-w-6xl px-6 pt-24 md:pt-32">
        <div class="mx-auto max-w-3xl text-center">
          <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-border bg-card px-4 py-1.5 text-sm text-muted-foreground">
            <span class="inline-block h-2 w-2 rounded-full bg-success animate-pulse"></span>
            Open source &mdash; MIT License
          </div>

          <h1 class="text-4xl font-bold leading-tight tracking-tight text-text md:text-6xl">
            The agent-first<br />
            <span class="bg-gradient-to-r from-primary to-primary-hover bg-clip-text text-transparent">IDE</span>
          </h1>

          <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-muted-foreground md:text-xl">
            A desktop IDE designed from the ground up for AI coding agents.
            Chat panes, terminals, browsers, and a code editor &mdash; all wired up
            to dispatch tasks to Claude Code, Codex, or OpenCode and run them in
            parallel against isolated git worktrees.
          </p>

          <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
            <a
              href="https://github.com/band-app/band/releases/latest"
              data-download="hero"
              class="inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-3 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary-hover"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="7 10 12 15 17 10"/>
                <line x1="12" y1="15" x2="12" y2="3"/>
              </svg>
              Download for macOS
            </a>
            <a
              href="https://github.com/band-app/band"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg border border-border bg-card px-6 py-3 text-sm font-medium text-text transition-colors hover:bg-accent"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              View on GitHub
            </a>
          </div>

          <!-- Value props -->
          <div class="mt-14 grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div class="rounded-xl border border-border bg-card/50 px-5 py-4 text-left">
              <div class="mb-1 text-sm font-medium text-text">Designed for agents from day one</div>
              <div class="text-sm text-muted-foreground">Chat panes, editor, terminal, and browser tabs &mdash; every pane scoped to a workspace and an agent.</div>
            </div>
            <div class="rounded-xl border border-border bg-card/50 px-5 py-4 text-left">
              <div class="mb-1 text-sm font-medium text-text">Bring your own coding agent</div>
              <div class="text-sm text-muted-foreground">Claude Code, Codex, OpenCode &mdash; swappable per chat pane, no workflow changes.</div>
            </div>
            <div class="rounded-xl border border-border bg-card/50 px-5 py-4 text-left">
              <div class="mb-1 text-sm font-medium text-text">Git worktree isolation by default</div>
              <div class="text-sm text-muted-foreground">Every workspace is its own branch and worktree. Run agents in parallel without stepping on each other.</div>
            </div>
            <div class="rounded-xl border border-border bg-card/50 px-5 py-4 text-left">
              <div class="mb-1 text-sm font-medium text-text">Drop into your editor when you need to</div>
              <div class="text-sm text-muted-foreground">One click opens the active worktree in VS Code, Cursor, Zed, JetBrains, or Xcode for hands-on edits.</div>
            </div>
          </div>
        </div>

      </div>

      <!-- Dashboard screenshot (breaks out of the max-w-6xl hero container so it can be wider) -->
      <div class="relative mx-auto mt-16 max-w-[100rem] px-6 pb-20 md:pb-28">
        <img
          src="/screenshot-dashboard.png"
          alt="The Band desktop app: workspace sidebar on the far left, chat pane next to it, project file tree in the middle, and a code editor on the right showing the active worktree."
          width="1946"
          height="1187"
          loading="eager"
          decoding="async"
          class="block h-auto w-full rounded-xl shadow-2xl shadow-black/40"
        />
      </div>
    </section>

    <!-- Problem Section -->
    <section class="border-t border-border py-20 md:py-28">
      <div class="mx-auto max-w-6xl px-6">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="text-3xl font-bold tracking-tight text-text md:text-4xl">
            Your IDE wasn't built for this
          </h2>
          <p class="mt-4 text-lg text-muted-foreground">
            Traditional editors were designed for one human at a keyboard &mdash; not a fleet of AI agents working in parallel.
          </p>
        </div>

        <div class="mt-14 grid gap-6 md:grid-cols-2">
          <div class="rounded-xl border border-border bg-card/50 p-6">
            <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-muted text-muted-foreground">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-text">No place built to watch agents</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
              Agents get crammed into terminal panes that were designed for shells, not for streaming chats, file diffs, and tool-call output side by side.
            </p>
          </div>

          <div class="rounded-xl border border-border bg-card/50 p-6">
            <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-muted text-muted-foreground">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-text">Agents step on each other</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
              Two agents in the same checkout is a guaranteed conflict. Without per-task isolation, running them in parallel is dangerous.
            </p>
          </div>

          <div class="rounded-xl border border-border bg-card/50 p-6">
            <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-muted text-muted-foreground">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-text">No task queue</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
              You can't dispatch a batch of tasks to agents and come back later. Every task needs manual setup.
            </p>
          </div>

          <div class="rounded-xl border border-border bg-card/50 p-6">
            <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-muted text-muted-foreground">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-text">No automation</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">
              Repetitive agent tasks like code reviews, dependency updates, and daily reports can't be scheduled.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- How It Works Section -->
    <section class="border-t border-border bg-card py-20 md:py-28">
      <div class="mx-auto max-w-6xl px-6">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="text-3xl font-bold tracking-tight text-text md:text-4xl">
            How it works
          </h2>
          <p class="mt-4 text-lg text-muted-foreground">
            Four steps from install to your first agent-driven task.
          </p>
        </div>

        <div class="mt-14 grid gap-8 md:grid-cols-4">
          <div class="relative text-center">
            <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-primary/10 text-2xl font-bold text-primary">
              1
            </div>
            <h3 class="text-lg font-semibold text-text">Register projects</h3>
            <p class="mt-2 text-sm text-muted-foreground">
              Point Band at your git repos. It discovers branches, worktrees, and configuration automatically.
            </p>
          </div>

          <div class="relative text-center">
            <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-primary/10 text-2xl font-bold text-primary">
              2
            </div>
            <h3 class="text-lg font-semibold text-text">Create workspaces</h3>
            <p class="mt-2 text-sm text-muted-foreground">
              Each workspace gets an isolated git worktree with its own branch. No conflicts with your main work.
            </p>
          </div>

          <div class="relative text-center">
            <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-primary/10 text-2xl font-bold text-primary">
              3
            </div>
            <h3 class="text-lg font-semibold text-text">Dispatch tasks</h3>
            <p class="mt-2 text-sm text-muted-foreground">
              Send prompts to coding agents. Watch their output stream in real-time from the dashboard.
            </p>
          </div>

          <div class="relative text-center">
            <div class="mx-auto mb-4 flex h-14 w-14 items-center justify-center rounded-2xl bg-primary/10 text-2xl font-bold text-primary">
              4
            </div>
            <h3 class="text-lg font-semibold text-text">Monitor status</h3>
            <p class="mt-2 text-sm text-muted-foreground">
              See agent activity, git changes, and CI status at a glance. From desktop or mobile.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Feature Highlights Section -->
    <section class="border-t border-border py-20 md:py-28">
      <div class="mx-auto max-w-6xl px-6">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="text-3xl font-bold tracking-tight text-text md:text-4xl">
            Everything you need
          </h2>
          <p class="mt-4 text-lg text-muted-foreground">
            Workspaces, agents, automation, and remote access &mdash; all built into the IDE.
          </p>
        </div>

        <div class="mt-14 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {[
            {
              icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
              title: "Multi-agent support",
              desc: "Claude Code, Codex, OpenCode. Swap coding agents per chat pane.",
            },
            {
              icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
              title: "Real-time status",
              desc: "Live agent status, git dirty/ahead/behind indicators, and CI pass/fail at a glance.",
            },
            {
              icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
              title: "Task management",
              desc: "Submit, cancel, re-run, and watch tasks in real-time. Full task history.",
            },
            {
              icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
              title: "Scheduled tasks",
              desc: "Automate recurring agent work with cron expressions. Code reviews, dependency updates, and more.",
            },
            {
              icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>`,
              title: "Remote access",
              desc: "Built-in Cloudflare tunnel. Access your dashboard from anywhere, including mobile.",
            },
            {
              icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" y1="19" x2="20" y2="19"/></svg>`,
              title: "CLI-first",
              desc: "Every operation is scriptable via the band CLI. JSON output mode for automation.",
            },
            {
              icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/></svg>`,
              title: "Git worktree isolation",
              desc: "Clean branch-per-task workflow. Every workspace is isolated from the main branch.",
            },
            {
              icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>`,
              title: "Setup & teardown scripts",
              desc: "Per-project .band/config.json for automation. Run scripts on workspace creation and removal.",
            },
            {
              icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
              title: "Editor & app integrations",
              desc: "One click opens the active worktree in VS Code, Cursor, Zed, all JetBrains IDEs, Xcode, iTerm2, Warp, Ghostty, Chrome, Safari, or Firefox.",
            },
          ].map(({ icon, title, desc }) => (
            <div class="group rounded-xl border border-border bg-card/30 p-5 transition-colors hover:bg-card/60">
              <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 text-primary transition-colors group-hover:bg-primary/20">
                <Fragment set:html={icon} />
              </div>
              <h3 class="text-sm font-semibold text-text">{title}</h3>
              <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="border-t border-border bg-card py-20 md:py-28">
      <div class="mx-auto max-w-6xl px-6">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="text-3xl font-bold tracking-tight text-text md:text-4xl">
            Try the agent-first IDE
          </h2>
          <p class="mt-4 text-lg text-muted-foreground">
            Download Band and start running coding agents in parallel today.
          </p>
          <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
            <a
              href="https://github.com/band-app/band/releases/latest"
              data-download="bottom-cta"
              class="inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-3 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary-hover"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
                <polyline points="7 10 12 15 17 10"/>
                <line x1="12" y1="15" x2="12" y2="3"/>
              </svg>
              Download for macOS
            </a>
            <a
              href="/docs/getting-started"
              class="inline-flex items-center gap-2 rounded-lg border border-border bg-card px-6 py-3 text-sm font-medium text-text transition-colors hover:bg-accent"
            >
              Read the docs
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
