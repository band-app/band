{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "ignoreWorkspaces": ["apps/cli"],
  "exclude": ["exports", "types", "unresolved"],
  "ignoreBinaries": ["wrangler"],
  "workspaces": {
    ".": {
      "entry": ["scripts/*.mjs"],
      "ignoreDependencies": [
        "@band-app/cli",
        "@tanstack/react-query",
        "@trpc/client",
        "@trpc/server"
      ]
    },
    "apps/web": {
      "entry": [
        "src/client.tsx",
        "src/server.ts",
        "src/router.tsx",
        "src/dashboard/index.ts",
        "src/dashboard/adapters/web.ts",
        "src/dashboard/adapters/desktop.ts",
        "bin/band-server.mjs",
        "start-server.ts"
      ],
      "project": ["src/**/*.{ts,tsx}", "tests/**/*.ts", "e2e/**/*.ts"],
      "ignoreDependencies": [
        "tailwindcss",
        "tw-animate-css",
        "class-variance-authority",
        "clsx",
        "tailwind-merge",
        "@tanstack/router-plugin",
        "nanoid",
        "typescript-language-server",
        "vscode-jsonrpc",
        "@babel/runtime",
        "@codemirror/lint",
        "esbuild"
      ]
    },
    "apps/desktop": {
      "entry": [
        "src/main/index.ts",
        "src/preload/index.cts",
        "tests/**/*.test.ts",
        "tests/**/*.test.mjs",
        "tests/loader.mjs",
        "scripts/*.mjs"
      ],
      "project": ["src/**/*.{ts,cts}", "tests/**/*.{ts,mjs}", "scripts/**/*.mjs"],
      "ignoreBinaries": ["tsc", "electron", "electron-builder"],
      "ignoreDependencies": ["electron-builder"]
    },
    "apps/website": {
      "entry": ["src/**/*.{astro,ts,tsx}"],
      "project": ["src/**/*.{astro,ts,tsx}"],
      "ignoreDependencies": ["tailwindcss"]
    },
    "packages/ui": {
      "entry": ["src/index.ts", "src/utils.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/coding-agent": {
      "entry": ["src/index.ts", "tests/mocks/*.mjs"],
      "project": ["src/**/*.ts", "tests/**/*.{ts,mjs}"]
    },
    "packages/logger": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    }
  }
}
